{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "api": "node --env-file-if-exists=.env backend/src/index.js",
    "start": "node --env-file-if-exists=.env backend/src/index.js",
    "db:init": "node --env-file-if-exists=.env scripts/run-postgres-file.mjs database/postgres/schema.sql && node --env-file-if-exists=.env scripts/run-postgres-file.mjs database/postgres/seed.sql",
    "db:schema": "node --env-file-if-exists=.env scripts/run-postgres-file.mjs database/postgres/schema.sql",
    "db:seed": "node --env-file-if-exists=.env scripts/run-postgres-file.mjs database/postgres/seed.sql",
    "db:migrate:race-actions": "node --env-file-if-exists=.env scripts/run-postgres-file.mjs database/postgres/migrations/002_race_action_logs.sql",
    "build": "vite build --config frontend/vite.config.ts",
    "test": "node --test backend/test/*.test.js",
    "test:auth": "node --test backend/test/auth-flow.test.js",
    "test:referee": "node --test backend/test/referee-flow.test.js",
    "dev": "vite --config frontend/vite.config.ts --host 127.0.0.1",
    "preview": "vite preview --config frontend/vite.config.ts --host 127.0.0.1"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "bcryptjs": "^3.0.3",
    "hono": "^4.12.26",
    "lucide-react": "0.487.0",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "rollup": "^4.60.4",
    "tailwindcss": "^3.4.3",
    "vite": "^6.4.3"
  }
}
